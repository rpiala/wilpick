@using WilPick.ViewModels;
@model PlayerLoadDetailViewModel;

@{
    ViewData["Title"] = "Create Load Transaction";
}

<h1>Cash-IN Transaction</h1>
<hr />

<div class="row">
    <div class="col-12">
        <form asp-action="CreateLoadTransaction" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>           
            <input asp-for="LoadId" type="hidden" />
            <input asp-for="UserId" type="hidden" />
            <input asp-for="RequestedDate" type="hidden" />
            <input asp-for="ApprovedDate" type="hidden" />            
            <input asp-for="ApprovedAmount" type="hidden" />
            <input asp-for="ApprovedBy" type="hidden" />
            <input asp-for="IsApproved" type="hidden" />
            <input asp-for="AttachmentFilename" type="hidden" />

            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="ReferenceNo" class="form-label">Reference / Remarks</label>
                        <input asp-for="ReferenceNo"
                               class="form-control fw-semibold"
                               disabled />
                    </div>
            
                    <div class="mb-3">
                        <label asp-for="ReceiverMobileNumber" class="form-label">
                            Receiver Mobile Number
                        </label>
                        <div class="input-group">                            
                            <select asp-for="ReceiverMobileNumber"
                                    asp-items="Model.ReceiverMobileNumbers"
                                    class="form-select">
                                <option value="">-- Select Receiver --</option>
                            </select>                            
                        </div>
                        <span asp-validation-for="ReceiverMobileNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="RequestedAmount" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text">₱</span>
                            <input asp-for="RequestedAmount"
                                   class="form-control"
                                   inputmode="numeric"
                                   maxlength="10"
                                   oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10);" />
                            <span asp-validation-for="RequestedAmount" class="text-danger"></span>
                        </div>
                        

                        <div class="form-text">
                            Enter amount in whole numbers only.
                        </div>
                    </div>                   

                    <div class="mb-3">
                        <label asp-for="Attachment" class="form-label">
                            Upload Proof of Payment
                        </label>

                        <input asp-for="Attachment"
                               type="file"
                               id="AttachmentInput"
                               class="form-control"
                               accept=".jpg,.jpeg,.png,.pdf" />

                        <span asp-validation-for="Attachment" class="text-danger"></span>
                        <small class="text-muted">
                            Max file size: 5 MB. Allowed: JPG, PNG, PDF
                        </small>
                    </div>

                    
                    @if (!string.IsNullOrEmpty(Model?.AttachmentFilename))
                    {
                        <div class="mb-3">
                            <a href="@Url.Content($"~/uploads/{Model.AttachmentFilename}")"
                               target="_blank"
                               class="link-primary">
                                <i class="fa-solid fa-paperclip me-1"></i>
                                View uploaded attachment
                            </a>
                        </div>
                    }
                    
                    <div class="form-group mt-2">
                        <a asp-controller="Transactions" asp-action="PlayerLoadTransactions" class="btn btn-danger">Back</a>
                        @if (Model?.IsApproved == 0)
                        {
                            <input type="submit" value="Save" class="btn btn-primary" />
                        }
                    </div>
                </div>
            </div>  
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }


    <script>
        document.getElementById("AttachmentInput")?.addEventListener("change", function () {
            const file = this.files[0];
            if (!file) return;

            const maxSize = 5 * 1024 * 1024; // 10 MB
            const forbiddenExtensions = ['exe', 'bat'];

            const fileExtension = file.name.split('.').pop().toLowerCase();

            if (file.size > maxSize) {
                alert("File size must not exceed 5 MB.");
                this.value = "";
                return;
            }

            if (forbiddenExtensions.includes(fileExtension)) {
                alert("Executable files (.exe, .bat) are not allowed.");
                this.value = "";
                return;
            }
        });
    </script>

}