@using WilPick.ViewModels;
@model CashOutDetailViewModel;

@{
    ViewData["Title"] = "Cash-OUT Transaction";
}

<h1>Cash-OUT Transaction</h1>
<hr />

<div class="row">
    <div class="col-12">
        <form asp-action="CashOutDetail" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input asp-for="CashOutId" type="hidden" />
            <input asp-for="UserId" type="hidden" />
            <input asp-for="RequestedDate" type="hidden" />            
            <input asp-for="ProcessedBy" type="hidden" />
            <input asp-for="IsCompleted" type="hidden" />
            <input asp-for="AttachmentFilename" type="hidden" />

            <div class="card shadow-sm">
                <div class="card-body">                    
                    <div class="mb-3">
                        <label asp-for="ReceiverMobileNumber" class="form-label">
                            Receiver Mobile Number
                        </label>                       
                        <div class="input-group">
                            <input asp-for="ReceiverMobileNumber"
                                   class="form-control"
                                   type="text"
                                   maxlength="11"
                                   inputmode="numeric"
                                   pattern="[0-9]{11}"
                                   oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 11);" />
                        </div>
                        <span asp-validation-for="ReceiverMobileNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ReceiverName" class="form-label"></label>
                        <input asp-for="ReceiverName" class="form-control" />
                        <span asp-validation-for="ReceiverName" class="text-danger"></span>
                    </div>

                    @if (Model.CashOutId == 0)
                    {
                        <div class="mb-3">
                            <label asp-for="LoadBalance" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">₱</span>
                                <input asp-for="LoadBalance"
                                class="form-control"
                                inputmode="numeric"
                                maxlength="10"
                                oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10);" disabled/>
                            </div>                        
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="CashOutAmount" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text">₱</span>
                            <input asp-for="CashOutAmount"
                                   class="form-control"
                                   inputmode="numeric"
                                   maxlength="10"
                                   oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10);" />
                        </div>
                        <span asp-validation-for="CashOutAmount" class="text-danger"></span>

                        <div class="form-text">
                            Enter amount in whole numbers only and should be more than your load balance.
                        </div>
                    </div>

                    @* <div class="mb-3">
                        <label asp-for="Attachment" class="form-label">
                            Upload Proof of Payment
                        </label>
                        <input asp-for="Attachment"
                               type="file"
                               class="form-control"
                               accept=".jpg,.jpeg,.png,.pdf" />
                        <span asp-validation-for="Attachment" class="text-danger"></span>
                    </div> *@

                    @if (!string.IsNullOrEmpty(Model?.AttachmentFilename))
                    {
                        <div class="mb-3">
                            <a href="@Url.Content($"~/uploads/{Model.AttachmentFilename}")"
                               target="_blank"
                               class="link-primary">
                                <i class="fa-solid fa-paperclip me-1"></i>
                                View uploaded attachment
                            </a>
                        </div>
                    }

                    <div class="form-group mt-2">
                        <a asp-controller="Transactions" asp-action="CashOutTransactions" class="btn btn-danger">Back</a>
                        @if (Model?.IsCompleted == 0)
                        {
                            <input type="submit" value="Save" class="btn btn-primary" />
                        }
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const mobileInput = document.getElementById("ReceiverMobileNumber");
            if (mobileInput) {
                mobileInput.focus();
            }          
            });
    </script>

}