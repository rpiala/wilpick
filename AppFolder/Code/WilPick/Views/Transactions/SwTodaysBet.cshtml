@using WilPick.ViewModels;
@using Constants = WilPick.Common.Constant;
@model SwCoBetHdrViewModel;
@{
    // ViewData["Title"] = "Todays Bet";
    // bool isCuttOff = ViewData["IsCuttOff"] is bool b && b;
}

<h1 style="color: red;">
    S3 Next Draw Date -
    @(((DateTime)ViewData["DrawDate"]).ToString("MMM dd, yyyy hh:mmtt"))
</h1>

<hr />

<div class="d-flex gap-4 mb-3">

    <!-- Load Balance -->
    <div>
        <div class="text-uppercase fw-semibold text-muted mb-1">
            Load Balance
        </div>
        <div class="d-flex align-items-center">
            <i class="fa-solid fa-coins text-warning me-2 fs-3"></i>
            <span class="fw-bold fs-3">
                ₱@string.Format("{0:N2}", Model.PlayerRemainingload)
            </span>
        </div>
    </div>

    <!-- Second Item -->
    <div>
        <div class="text-uppercase fw-semibold text-muted mb-1">
            Total Cash-IN: ₱@string.Format("{0:N2}", Model.TotalCashIn)
        </div>
        <div class="text-uppercase fw-semibold text-muted mb-1">
            Total BET: ₱@string.Format("{0:N2}", Model.OverallTotalBet)
        </div>
        <div class="text-uppercase fw-semibold text-muted mb-1">
            Total Cash-OUT: ₱@string.Format("{0:N2}", Model.TotalCashOut)
        </div>
    </div>

</div>


@if (!Model.IsCuttOff)
{
    <div class="d-flex justify-content-end mb-2">
        @if (Model.BetType == Constants.LOADTYPE && Model.PlayerRemainingload <= 0)
        {
            <button class="btn btn-success me-2"
                    disabled
                    title="Insufficient load">
                Create Bet
            </button>
        }
        else
        {
            <a class="btn btn-success me-2"
               asp-controller="Transactions"
               asp-action="SwCreateBet">
                Create Bet
            </a>
        }
    </div>

    @if (Model.BetType == Constants.LOADTYPE && Model.PlayerRemainingload <= 0)
    {
        <div class="alert alert-danger mt-2">
            You have insufficient load to place a bet.
        </div>
    }
}
else
{
    <div class="alert alert-warning">
        Betting is closed for this draw.
    </div>
}


@if (Model?.BetDetails != null && Model.BetDetails.Any())
{
    <div class="alert alert-secondary text-end fw-bold mb-2">
        Total Bet:
        <span class="text-primary">
            ₱@string.Format("{0:N2}", @Model.TotalBetAmount)
        </span>
    </div>

    <table class="table table-responsive table-striped table-hover align-middle">
        <thead>
            <tr class="text-center">
                <th>@Html.DisplayNameFor(model => model.BetDetails[0].RowNum)</th>
                <th>@Html.DisplayNameFor(model => model.BetDetails[0].cbd_msg)</th>
                <th>@Html.DisplayNameFor(model => model.BetDetails[0].cbd_bet)</th>                
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var betDetail in Model.BetDetails)
            {
                <tr class="text-center">
                    <td>@Html.DisplayFor(model => betDetail.RowNum)</td>
                    <td>@Html.DisplayFor(model => betDetail.cbd_msg)</td>
                    <td>@Html.DisplayFor(model => betDetail.cbd_bet)</td>                    
                    <td>
                        @if (!Model.IsCuttOff)
                        {
                            <a asp-controller="Transactions" asp-action="SwCreateBet" asp-route-cbdDtlNoEnc="@betDetail.cbd_dtl_no_enc" class="btn btn-primary">Edit</a>
                            <a asp-controller="Transactions" asp-action="DeleteSwBet" asp-route-cbdDtlNoEnc="@betDetail.cbd_dtl_no_enc" class="btn btn-danger">Del</a>
                        }
                        else
                        {
                            <span class="text-muted">Cut‑off</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">No bet details available.</div>
}