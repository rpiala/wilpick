@using WilPick.ViewModels;
@model PlayerHistoryBetHeaderViewModel;
@{
    // ViewData["Title"] = "Todays Bet";
    // bool isCuttOff = ViewData["IsCuttOff"] is bool b && b;
}

<h1>Player Bet History</h1>
<hr />

@* <div class="row">
    <div class="col-12"> *@
<form asp-action="PlayerBetHistory" method="post" class="row g-3 mb-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-3">
        <label asp-for="FromDate" class="form-label"></label>
        <input asp-for="FromDate" type="date" class="form-control" />
    </div>

    <div class="col-md-3">
        <label asp-for="ToDate" class="form-label"></label>
        <input asp-for="ToDate" type="date" class="form-control" />
    </div>    

    <div class="col-md-3 align-self-end">
        <button type="submit" class="btn btn-primary">
            Retrieve
        </button>
    </div>

    @if (Model?.BetDetails != null && Model.BetDetails.Any())
    {

        <div class="alert alert-secondary text-end fw-bold mb-2">
            Total Bet:
            <span class="text-primary">
                ₱@string.Format("{0:N2}",@Model.TotalBetAmount)
            </span>
        </div>

        <table class="table table-responsive table-striped table-hover align-middle">
            <thead>
                <tr class="text-center">
                    <th>@Html.DisplayNameFor(model => model.BetDetails[0].RowNum)</th>
                    <th>@Html.DisplayNameFor(model => model.BetDetails[0].DrawDate)</th>
                    <th>@Html.DisplayNameFor(model => model.BetDetails[0].Combination)</th>
                    <th>@Html.DisplayNameFor(model => model.BetDetails[0].BetAmount)</th>
                    <th>@Html.DisplayNameFor(model => model.BetDetails[0].RambleBetAmount)</th>
                    <th>@Html.DisplayNameFor(model => model.BetDetails[0].DrawDisplay)</th>                    
                    <th>@Html.DisplayNameFor(model => model.BetDetails[0].TotalBet)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var betDetail in Model.BetDetails)
                {
                    <tr class="text-center">
                        <td>@Html.DisplayFor(model => betDetail.RowNum)</td>
                         <td>@Html.DisplayFor(model => betDetail.DrawDate)</td>
                        <td>@Html.DisplayFor(model => betDetail.Combination)</td>
                        <td>@Html.DisplayFor(model => betDetail.BetAmount)</td>
                        <td>@Html.DisplayFor(model => betDetail.RambleBetAmount)</td>
                        <td>@Html.DisplayFor(model => betDetail.DrawDisplay)</td>                        
                        <td>@Html.DisplayFor(model => betDetail.TotalBet)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">No bet details available.</div>
    }
</form>
@* </div>
</div> *@

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}