@using WilPick.ViewModels;
@model SwCoBetDtlViewModel;

@{
    ViewData["Title"] = "Create S3 Bet";
}

<h1>Create S3 Bet</h1>
<hr />
<div class="card shadow-sm">
    <div class="card-body">
        <div class="row">
            <div class="col-12">
                <form asp-action="SwCreateBet" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    @* Hidden fields for values that must be posted but are not visible/bound *@
                    <input asp-for="cbd_dtl_no" type="hidden" />
                    <input asp-for="cbh_no" type="hidden" />
                    <input asp-for="cvm_no" type="hidden" />
                    <input asp-for="cbd_dtl_no_enc" type="hidden" />
                    <input asp-for="user_id" type="hidden" />
                    <input asp-for="cw_id" type="hidden" />
                    <input asp-for="co_id" type="hidden" />
                    <input asp-for="wp_id" type="hidden" />
                    <input asp-for="SwEntries" type="hidden" />
                    <input asp-for="prev_cbd_msg" type="hidden" />
                    <input asp-for="prev_cbd_bet" type="hidden" />

                    <div class="form-group">
                        <div class="mb-3">
                            <label asp-for="LoadBalance" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">₱</span>
                                <input asp-for="LoadBalance"
                                       id="LoadBalance"
                                       class="form-control text-start"
                                       readonly />

                            </div>
                        </div>

                        <label asp-for="cbd_msg" class="control-label"></label>
                        <div class="d-flex align-items-center gap-3">
                            <input asp-for="cbd_msg"
                                   class="form-control"
                                   style="max-width: 200px;"
                                   type="text"
                                   maxlength="3"
                                   minlength="3"
                                   inputmode="numeric"
                                   pattern="^\d{3}$"
                                   title="Enter exactly 3 numeric digits."
                                   oninput="this.value = this.value.replace(/[^0-9]/g,'').slice(0,3);" />
                        </div>
                        <span asp-validation-for="cbd_msg" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <div class="row align-items-start">
                            <!-- Column 1: Bet Amount -->
                            <div class="col-md-4">
                                <label asp-for="target" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text">₱</span>
                                    <input asp-for="target"
                                           type="number"
                                           class="form-control"
                                           step="1"
                                           min="0"
                                           inputmode="numeric"
                                           oninput="this.value = this.value.replace(/[^0-9]/g,'')" />
                                </div>
                                <span asp-validation-for="target" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="row align-items-start">
                            <!-- Column 1: Ramble Bet Amount -->
                            <div class="col-md-4">
                                <label asp-for="ramble" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text">₱</span>
                                    <input asp-for="ramble"
                                           type="number"
                                           class="form-control"
                                           step="1"
                                           min="0"
                                           inputmode="numeric"
                                           oninput="this.value = this.value.replace(/[^0-9]/g,'')" />
                                </div>
                                <span asp-validation-for="ramble" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    <div class="form-group mt-2">
                        <label for="PossibleWinningStraight" class="form-label">
                            Possible Winning (Straight)
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">₱</span>
                            <input type="text"
                                   id="PossibleWinningStraight"
                                   class="form-control text-start"
                                   readonly />

                        </div>
                    </div>
                    <div class="form-group mt-2">
                        <label for="PossibleWinningRamble" class="form-label">
                            Possible Winning (Ramble)
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">₱</span>
                            <input type="text"
                                   id="PossibleWinningRamble"
                                   class="form-control"
                                   readonly />
                        </div>
                    </div>
                    
                    <div class="form-group mt-2">
                        <a asp-controller="Transactions" asp-action="SwTodaysBet" class="btn btn-danger">Back</a>
                        <input type="submit" value="Save" class="btn btn-primary" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // ---------- Helper: format numbers ----------
            function formatCurrency(input) {
                if (!input || input.value === "") return;

                const value = parseFloat(input.value.replace(/,/g, ""));
                if (!isNaN(value)) {
                    input.value = value.toLocaleString("en-US", {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    });
                }
            }

            // ---------- Get elements ----------
            const combiInput = document.getElementById("cbd_msg");
            if (combiInput) combiInput.focus();

            const lb = document.getElementById("LoadBalance");
            const betAmountInput = document.getElementById("target");
            const rambleBetAmountInput = document.getElementById("ramble");
           
            const possibleWinningStraight = document.getElementById("PossibleWinningStraight");
            const possibleWinningRamble = document.getElementById("PossibleWinningRamble");

            // ✅ Injected safely from model
            const winningPrize = @Html.Raw(Json.Serialize(Model.WinningPrize ?? 0));            

            // ---------- Calculate ----------
            function calculateTotal() {
                const betAmount = parseInt(betAmountInput.value || "0", 10);
                const rambleBetAmount = parseInt(rambleBetAmountInput.value || "0", 10);
              
                possibleWinningStraight.value =
                    (betAmount * winningPrize).toFixed(2);

                possibleWinningRamble.value =
                    (rambleBetAmount * winningPrize).toFixed(2);

                // ✅ Format after calculation
                formatCurrency(lb);                
                formatCurrency(possibleWinningStraight);
                formatCurrency(possibleWinningRamble);
            }

            // ---------- Init ----------
            calculateTotal();

            // ---------- Events ----------
            betAmountInput.addEventListener("input", calculateTotal);
            rambleBetAmountInput.addEventListener("input", calculateTotal);            
        });
    </script>

}