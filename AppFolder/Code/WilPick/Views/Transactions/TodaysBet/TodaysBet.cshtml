@using WilPick.ViewModels;
@using Constants = WilPick.Common.Constant;
@model WpBetHeaderViewModel;
@{
    // ViewData["Title"] = "Todays Bet"; 
    // bool isCuttOff = ViewData["IsCuttOff"] is bool b && b;
}

<h1>Today's Bet - @(((DateTime)ViewData["DrawDate"]).ToString("MMM dd, yyyy hh:mmtt"))</h1>
<hr />

@if (Model.BetType == Constants.LOADTYPE )
{
    <div class="mb-3">
        <strong>LOAD:</strong>
        <span class="@(Model.PlayerRemainingload <= 0 ? "text-danger fw-bold" : "text-success fw-bold")">
            @Model.PlayerRemainingload
        </span>
    </div>
}

@* Visible, robust container for create buttons *@


@if (!Model.IsCuttOff)
{
    <div class="d-flex justify-content-end mb-2">
        @if (Model.BetType == Constants.LOADTYPE && Model.PlayerRemainingload <= 0)
        {
            <button class="btn btn-success me-2"
                    disabled
                    title="Insufficient load">
                Create Bet
            </button>
        }
        else
        {            
            <a class="btn btn-success me-2"
               asp-controller="Transactions"
               asp-action="CreateBet">
                Create Bet
            </a>
        }
    </div>

    @if (Model.BetType == Constants.LOADTYPE && Model.PlayerRemainingload <= 0)
    {
        <div class="alert alert-danger mt-2">
            You have insufficient load to place a bet.
        </div>
    }
}
else
{
    <div class="alert alert-warning">
        Betting is closed for this draw.
    </div>
}


@if (Model?.BetDetails != null && Model.BetDetails.Any())
{
    <table class="table table-responsive table-striped table-hover align-middle">
        <thead>
            <tr class="text-center">
                <th>@Html.DisplayNameFor(model => model.BetDetails[0].Combination)</th>
                <th>@Html.DisplayNameFor(model => model.BetDetails[0].BetAmount)</th>
                <th>@Html.DisplayNameFor(model => model.BetDetails[0].DrawDisplay)</th>
                <th>@Html.DisplayNameFor(model => model.BetDetails[0].TotalBet)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var betDetail in Model.BetDetails)
            {
                <tr class="text-center">
                    <td>@Html.DisplayFor(model => betDetail.Combination)</td>
                    <td>@Html.DisplayFor(model => betDetail.BetAmount)</td>
                    <td>@Html.DisplayFor(model => betDetail.DrawDisplay)</td>
                    <td>@Html.DisplayFor(model => betDetail.TotalBet)</td>
                    <td>
                        @if (!Model.IsCuttOff)
                        {    
                            <a asp-controller="Transactions" asp-action="CreateBet" asp-route-betDetailIdEnc="@betDetail.BetDetailIdEnc" class="btn btn-primary">Edit</a>
                            <a asp-controller="Transactions" asp-action="DeleteBet" asp-route-betDetailIdEnc="@betDetail.BetDetailIdEnc" class="btn btn-danger">Delete</a>
                        }
                        else
                        {
                            <span class="text-muted">Cut‑off</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">No bet details available.</div>
}