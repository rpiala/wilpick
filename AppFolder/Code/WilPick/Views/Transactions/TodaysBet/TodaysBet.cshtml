@using WilPick.ViewModels;
@model WpBetHeaderViewModel;
@{
    ViewData["Title"] = "Todays Bet";    
}

<h1>Todays Bet</h1>
<hr />
<a class="btn btn-success float-end" asp-controller="Transactions" asp-action="CreateBet">Create Bet</a>
<a class="btn btn-success float-end" asp-controller="Transactions" asp-action="CreateBet" asp-route-betDetailId="1">Create Bet 1</a>
<table class="table table-responsive table-striped table-hover align-middle">
    <thead>
        <tr class="text-center">
            <th>@Html.DisplayNameFor(model => model.BetDetails[0].Combination)</th>
            <th>@Html.DisplayNameFor(model => model.BetDetails[0].BetAmount)</th>
            @* <th>@Html.DisplayNameFor(model => model.Books[0].BookAuthor)</th> *@
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var betDetail in Model.BetDetails)
        {
            <tr class="text-center">
                <td>@Html.DisplayFor(model => betDetail.Combination)</td>
                <td>@Html.DisplayFor(model => betDetail.BetAmount)</td>
                @* <td>@Html.DisplayFor(model => book.BookAuthor)</td> *@
                <td>
                    <a asp-controller="Transactions" asp-action="CreateBet" asp-route-betDetailId="@betDetail.BetDetailId" class="btn btn-primary">Edit</a>
                    @* <a asp-page="./Detail" asp-route-id="@betDetail.BetDetailId" class="btn btn-success">Details</a> *@
                    <a asp-page="/DeleteBet" asp-route-id="@betDetail.BetDetailId" class="btn btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>