@using WilPick.ViewModels;
@model WpBetDetailViewModel;

@{
	ViewData["Title"] = "Create Bet";
}

<h1>Create Bet</h1>
<hr />
<div class="card shadow-sm">
    <div class="card-body">
        <div class="row">
            <div class="col-12">
                <form asp-action="CreateBet" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    @* Hidden fields for values that must be posted but are not visible/bound *@
                    <input asp-for="BetDetailId" type="hidden" />
                    <input asp-for="BetDetailIdEnc" type="hidden" />
                    <input asp-for="BetId" type="hidden" />
                    <input asp-for="UserId" type="hidden" />
                    <input asp-for="DateCreated" type="hidden" />           

                    @* Prev* hidden fields (if present on the model) to preserve previous values across postbacks *@
                    <input asp-for="PrevCombination" type="hidden" />
                    <input asp-for="PrevBetAmount" type="hidden" />
                    <input asp-for="PrevFirstDrawSelected" type="hidden" />
                    <input asp-for="PrevSecondDrawSelected" type="hidden" />
                    <input asp-for="PrevThirdDrawSelected" type="hidden" /> 
                    <input asp-for="IncludeRamble" type="hidden" />
            
                    <div class="form-group">
                        <div class="mb-3">
                            <label asp-for="LoadBalance" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">₱</span>
                                <input asp-for="LoadBalance"
                                       id="LoadBalance"
                                       class="form-control text-start"
                                       readonly />

                            </div>
                        </div>

                        <label asp-for="Combination" class="control-label"></label>
                        <div class="d-flex align-items-center gap-3">
                            <input asp-for="Combination"
                                   class="form-control"
                                   style="max-width: 200px;"
                                   maxlength="4"
                                   minlength="4"
                                   pattern="^(?!.*(.).*\1)[A-Z]{4}$"
                                   title="Four unique uppercase letters (A-Z) with no repeats."
                                   oninput="this.value = this.value.toUpperCase().replace(/[^A-Z]/g,'').slice(0,4);" />                            
                        </div>

                        <span asp-validation-for="Combination" class="text-danger"></span>
                    </div>


                    <div class="form-group">
                        <div class="row align-items-start">
                            <!-- Column 1: Bet Amount -->
                            <div class="col-md-4">
                                <label asp-for="BetAmount" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text">₱</span>
                                    <input asp-for="BetAmount"
                                           type="number"
                                           class="form-control"
                                           step="1"
                                           min="0"
                                           inputmode="numeric"
                                           oninput="this.value = this.value.replace(/[^0-9]/g,'')" />
                                </div>
                                <span asp-validation-for="BetAmount" class="text-danger"></span>
                            </div>                            
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="row align-items-start">
                            <!-- Column 1: Ramble Bet Amount -->
                            <div class="col-md-4">
                                <label asp-for="RambleBetAmount" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text">₱</span>
                                    <input asp-for="RambleBetAmount"
                                           type="number"
                                           class="form-control"
                                           step="1"
                                           min="0"
                                           inputmode="numeric"
                                           oninput="this.value = this.value.replace(/[^0-9]/g,'')" />
                                </div>
                                <span asp-validation-for="RambleBetAmount" class="text-danger"></span>
                            </div>                            
                        </div>
                    </div>                    

                    <div class="form-group">
                        <div class="d-flex align-items-center gap-3">
                            <div class="form-group form-check mt-2">
                                @* <input type="hidden" name="FirstDrawSelected" value="0" /> *@
                                <input type="checkbox"
                                       name="FirstDrawSelected"
                                       value="1"
                                       class="form-check-input"
                                       id="FirstDrawSelected"
                                       @(Model?.FirstDrawSelected == 1 ? "checked" : "") />
                                <label class="form-check-label" for="FirstDrawSelected">First Draw</label>
                                <span asp-validation-for="FirstDrawSelected" class="text-danger"></span>
                            </div>
                            <div class="form-group form-check mt-2">
                                @* <input type="hidden" name="SecondDrawSelected" value="0" /> *@
                                <input type="checkbox"
                                       name="SecondDrawSelected"
                                       value="1"
                                       class="form-check-input"
                                       id="SecondDrawSelected"
                                       @(Model?.SecondDrawSelected == 1 ? "checked" : "") />
                                <label class="form-check-label" for="SecondDrawSelected">Second Draw</label>
                                <span asp-validation-for="SecondDrawSelected" class="text-danger"></span>
                            </div>
                            <div class="form-group form-check mt-2">
                                @* <input type="hidden" name="ThirdDrawSelected" value="0" /> *@
                                <input type="checkbox"
                                       name="ThirdDrawSelected"
                                       value="1"
                                       class="form-check-input"
                                       id="ThirdDrawSelected"
                                       @(Model?.ThirdDrawSelected == 1 ? "checked" : "") />
                                <label class="form-check-label" for="ThirdDrawSelected">Third Draw</label>
                                <span asp-validation-for="ThirdDrawSelected" class="text-danger"></span>
                            </div>
						</div>
                    </div>
                    <div class="form-group mt-2">
                        <label for="PossibleWinningStraight" class="form-label">
                            Possible Winning (Straight)
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">₱</span>                            
                            <input type="text"
                                   id="PossibleWinningStraight"
                                   class="form-control text-start"
                                   readonly />

                        </div>
                    </div>   
                    <div class="form-group mt-2">
                        <label for="PossibleWinningRamble" class="form-label">
                            Possible Winning (Ramble)
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">₱</span>
                            <input type="text"
                                   id="PossibleWinningRamble"
                                   class="form-control"
                                   readonly />
                        </div>
                    </div>
                    <div class="form-group mt-2">
                        <label for="ComputedAmount" class="control-label">
                            Total Bet Amount
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">₱</span>
                            <input type="number"
                                   id="ComputedAmount"
                                   class="form-control"
                                   name="ComputedAmount"
                                   readonly />
                        </div>
                    </div>
                    <div class="form-group mt-2">
                        <a asp-controller="Transactions" asp-action="TodaysBet" class="btn btn-danger">Back</a>
                        <input type="submit" value="Save" class="btn btn-primary" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // ---------- Helper: format numbers ----------
            function formatCurrency(input) {
                if (!input || input.value === "") return;

                const value = parseFloat(input.value.replace(/,/g, ""));
                if (!isNaN(value)) {
                    input.value = value.toLocaleString("en-US", {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    });
                }
            }

            // ---------- Get elements ----------
            const combiInput = document.getElementById("Combination");
            if (combiInput) combiInput.focus();

            const lb = document.getElementById("LoadBalance");
            const betAmountInput = document.getElementById("BetAmount");
            const rambleBetAmountInput = document.getElementById("RambleBetAmount");

            const first = document.getElementById("FirstDrawSelected");
            const second = document.getElementById("SecondDrawSelected");
            const third = document.getElementById("ThirdDrawSelected");

            const computed = document.getElementById("ComputedAmount");
            const possibleWinningStraight = document.getElementById("PossibleWinningStraight");
            const possibleWinningRamble = document.getElementById("PossibleWinningRamble");

            // ✅ Injected safely from model
            const winningPrize = @Html.Raw(Json.Serialize(Model.WinningPrize ?? 0));
            const rambleWinningPrize = @Html.Raw(Json.Serialize(Model.RambleWinningPrize ?? 0));

            // ---------- Calculate ----------
            function calculateTotal() {
                const betAmount = parseInt(betAmountInput.value || "0", 10);
                const rambleBetAmount = parseInt(rambleBetAmountInput.value || "0", 10);

                const selectedCount =
                    (first.checked ? 1 : 0) +
                    (second.checked ? 1 : 0) +
                    (third.checked ? 1 : 0);

                const totalBet = (betAmount + rambleBetAmount) * selectedCount;
                computed.value = totalBet.toFixed(2);

                possibleWinningStraight.value =
                    (betAmount * winningPrize * selectedCount).toFixed(2);

                possibleWinningRamble.value =
                    (rambleBetAmount * rambleWinningPrize * selectedCount).toFixed(2);

                // ✅ Format after calculation
                formatCurrency(lb);
                formatCurrency(computed);
                formatCurrency(possibleWinningStraight);
                formatCurrency(possibleWinningRamble);
            }

            // ---------- Init ----------
            calculateTotal();

            // ---------- Events ----------
            betAmountInput.addEventListener("input", calculateTotal);
            rambleBetAmountInput.addEventListener("input", calculateTotal);

            first.addEventListener("change", calculateTotal);
            second.addEventListener("change", calculateTotal);
            third.addEventListener("change", calculateTotal);
        });
    </script>

}