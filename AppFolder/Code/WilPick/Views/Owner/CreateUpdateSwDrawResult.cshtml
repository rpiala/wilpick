@using WilPick.ViewModels;
@model SwDrawResultDetailViewModel;

@{
    ViewData["Title"] = "Draw Result";
}

<h1>Create S3 Draw Result</h1>
<hr />

<div class="row">
    <div class="col-12">
        <form asp-action="CreateUpdateSwDrawResult" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input asp-for="ResultNo" type="hidden" />

            <div class="form-group">
                <label asp-for="DrawSked" class="form-label"></label>
                <input asp-for="DrawSked" type="date" class="form-control" />
                <span asp-validation-for="DrawSked" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DrawTime" class="form-label"></label>
                <select asp-for="DrawTime" class="form-control">
                    <option value="">-- Select --</option>
                    <option value="1">2PM</option>
                    <option value="2">5PM</option>
                    <option value="3">9PM</option>
                </select>
                <span asp-validation-for="DrawTime" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ResultCombination" class="control-label"></label>
                <input asp-for="ResultCombination"
                       type="text"
                       class="form-control"
                       maxlength="3"
                       minlength="3"
                       inputmode="numeric"
                       pattern="^\d{3}$"
                       title="Enter exactly 3 numeric digits."
                       oninput="this.value = this.value.replace(/[^0-9]/g,'').slice(0,3);" />
                <span asp-validation-for="ResultCombination" class="text-danger"></span>
            </div>            
            <div class="form-group mt-2">
                <a asp-controller="Owner" asp-action="DrawSwResultsHeader" class="btn btn-danger">Back</a>
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}