@using WilPick.ViewModels;
@model DrawHolidayDetailViewModel;

@{
    ViewData["Title"] = "Draw Result";
}

<h1>Create Draw Result</h1>
<hr />

<div class="row">
    <div class="col-12">
        <form asp-action="CreateUpdateDrawHoliday" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input asp-for="HolidayId" type="hidden" />

            <div class="form-group">
                <label asp-for="HolidayDate" class="form-label"></label>
                <input asp-for="HolidayDate" type="date" class="form-control" />
                <span asp-validation-for="HolidayDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="HolidayName" class="control-label"></label>
                <input asp-for="HolidayName"
                       class="form-control"
                       inputmode="text"/>
                <span asp-validation-for="HolidayName" class="text-danger"></span>
            </div>        
            
            <div class="form-group">
                <div class="d-flex align-items-center gap-3">
                    <div class="form-group form-check mt-2">
                        @* <input type="hidden" name="FirstDrawSelected" value="0" /> *@
                        <input type="checkbox"
                               name="ApolPickFlag"
                               value="1"
                               class="form-check-input"
                               id="ApolPickFlag"
                               @(Model?.ApolPickFlag == 1 ? "checked" : "") />
                        <label class="form-check-label" for="ApolPickFlag">ApolPick</label>
                        <span asp-validation-for="ApolPickFlag" class="text-danger"></span>
                    </div>
                    <div class="form-group form-check mt-2">
                        @* <input type="hidden" name="SecondDrawSelected" value="0" /> *@
                        <input type="checkbox"
                               name="SwFlag"
                               value="1"
                               class="form-check-input"
                               id="SwFlag"
                               @(Model?.SwFlag == 1 ? "checked" : "") />
                        <label class="form-check-label" for="SwFlag">Second Draw</label>
                        <span asp-validation-for="SwFlag" class="text-danger"></span>
                    </div>                    
                </div>
            </div>

            <div class="form-group mt-2">
                <a asp-controller="Owner" asp-action="DrawHolidayHeader" class="btn btn-danger">Back</a>
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}