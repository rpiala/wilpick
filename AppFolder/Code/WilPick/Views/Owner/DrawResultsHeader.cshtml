@using WilPick.ViewModels;
@model DrawResultHeaderViewModel;
@{
    // ViewData["Title"] = "Todays Bet";
    // bool isCuttOff = ViewData["IsCuttOff"] is bool b && b;
}

<h1>Draw Results</h1>
<hr />

@* <div class="row">
    <div class="col-12"> *@
<form asp-action="DrawResultsHeader" method="post" class="row g-3 mb-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-3">
        <label asp-for="FromDate" class="form-label"></label>
        <input asp-for="FromDate" type="date" class="form-control" />
    </div>

    <div class="col-md-3">
        <label asp-for="ToDate" class="form-label"></label>
        <input asp-for="ToDate" type="date" class="form-control" />
    </div>    

    <div class="col-md-3 align-self-end">
        <button type="submit" class="btn btn-primary">
            Retrieve
        </button>
    </div>

    <div class="d-flex justify-content-end mb-2">
        <a class="btn btn-success me-2" asp-controller="Owner" asp-action="CreateUpdateDrawResult">Create Draw Result</a>
    </div>

    @if (Model?.Results != null && Model.Results.Any())
    {
        <table class="table table-responsive table-striped table-hover align-middle">
            <thead>
                <tr class="text-center">
                    <th>@Html.DisplayNameFor(model => model.Results[0].RowNum)</th>
                    <th>@Html.DisplayNameFor(model => model.Results[0].DrawDate)</th>
                    <th>@Html.DisplayNameFor(model => model.Results[0].FirstResult)</th>
                    <th>@Html.DisplayNameFor(model => model.Results[0].SecondResult)</th>
                    <th>@Html.DisplayNameFor(model => model.Results[0].ThirdResult)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var result in Model.Results)
                {
                    <tr class="text-center">
                        <td>@Html.DisplayFor(model => result.RowNum)</td>
                        <td>@Html.DisplayFor(model => result.DrawDate)</td>
                        <td>@Html.DisplayFor(model => result.FirstResult)</td>
                        <td>@Html.DisplayFor(model => result.SecondResult)</td>
                        <td>@Html.DisplayFor(model => result.ThirdResult)</td>

                        <td>
                            <a asp-controller="Owner" asp-action="CreateUpdateDrawResult" asp-route-ResultIdEnc="@result.ResultIdEnc" class="btn btn-primary">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">No results available.</div>
    }
</form>
@* </div>
</div> *@

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}